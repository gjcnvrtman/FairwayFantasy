# ─────────────────────────────────────────────────────────────
# Fairway Fantasy — local development env template
# ─────────────────────────────────────────────────────────────
# Copy this file to ``.env.local`` and fill in real values.
# ``.env.local`` is gitignored — never commit it.
#
# Two paths:
#
# 1. PREVIEW THE LANDING PAGE ONLY (no auth, no DB):
#    Leave these all empty. Run ``npm run dev``. The landing page at
#    http://localhost:3000/ renders without Supabase. Auth-gated pages
#    (/dashboard, /league/*, /create) will surface a clear error.
#    ``npm run build`` will still fail in this mode — Next.js
#    statically prerenders /dashboard and the API routes which need
#    Supabase. This is fine for visual landing-page review.
#
# 2. FULL DEV MODE (real Supabase Cloud project):
#    Create a free project at https://supabase.com, run
#    ``supabase/schema.sql`` in the SQL editor, then fill in the
#    URL/keys below. ``npm run build`` and ``npm run dev`` both work.
#    NOTE: per the prompt-1 review, the LAN deployment plan is to
#    REPLACE Supabase Cloud with a self-hosted Postgres + new auth.
#    This file is a stopgap for collaboration before that migration.
# ─────────────────────────────────────────────────────────────

# ── Supabase project ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ── Cron secret ──
# Used by /api/sync-scores to refuse calls without the right Bearer
# header. NOTE: do NOT prefix this with NEXT_PUBLIC_ — the prompt-1
# review flagged AdminPanel.tsx for exposing this secret to the
# client bundle. Remove that prefix when wiring real manual-sync.
CRON_SECRET=replace-with-a-random-string

# ── DataGolf API key (currently unused) ──
# README references this but datagolf.ts now sources rankings from
# ESPN's free API instead. Listed here for documentation only — leave
# blank.
# DATAGOLF_API_KEY=

# ── Public site URL ──
# Used in ``src/app/league/[slug]/page.tsx`` to build the absolute
# invite URL. For LAN deployment this should be ``http://192.168.1.160``
# (or whatever your final LAN URL is) — keeps the copy-button output
# correct.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
