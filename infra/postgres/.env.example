# Copy to .env (gitignored) and set a strong password.
# Use HEX (not base64) — base64 includes `/` and `+` which break
# Postgres URI parsing in DATABASE_URL.
#   openssl rand -hex 32         # 64-char hex, no URL-special chars
POSTGRES_PASSWORD=replace-with-output-of-openssl-rand-hex-32

# Host port. Default 5432. Bump for local dev if you have another
# Postgres running (e.g. POSTGRES_HOST_PORT=5434).
# POSTGRES_HOST_PORT=5432
